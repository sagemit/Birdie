    <span class="bl">Stats</span>
  </button>
</div></nav>
<div class="toast" id="toast"></div>
<script>
const store = {
  async get(k){
    if (window.storage) return window.storage.get(k);
    const v = localStorage.getItem(k);
    return v !== null ? {value: v} : null;
  },
  async set(k,v){
    if (window.storage) return window.storage.set(k,v);
    localStorage.setItem(k,v);
    return {key:k};
  }
};
let sessions = [], tab = 'log', draft = null, courseFilter = 'all', expanded = null;
const CLUBS = ['Driver','3W','5W','Hybrid','4i','5i','6i','7i','8i','9i','PW','GW','SW','LW'];
const DISTS = ['3 ft','6 ft','10 ft','20+ ft'];
const MISSES = ['Straight','Left','Right','Fat','Thin'];
const TEES = ['Driver','Wood/Hyb','Iron'];
const PGA = {3:{avg:3.06,gir:60.04,bird:13.45},4:{avg:4.05,gir:60.32,bird:16.35},5:{avg:4.67,gir:77.38,bird:42.01}};
const AFFIRM = [
  "Every swing today is information. You're always learning.",
  "You don't chase the score, you build it, one shot at a time.",
  "The short game is where quiet players win loudly.",
  "Every tee box is a fresh start.",
  "Consistency beats brilliance over 18 holes. Every time.",
  "Trust the practice. It's already in your hands.",
  "Tempo, not force. The ball goes further when you're calm.",
  "Great rounds are built on boring pars.",
  "You've made this putt a hundred times in practice.",
  "Patience today, rewards tomorrow.",
  "One target, one shot, one breath.",
  "Every day on the course makes you better.",
  "Fairways love a committed swing.",
  "Your best golf is ahead of you.",
  "Play the shot in front of you. That's the only one that matters.",
  "Small improvements every day become low rounds.",
  "Confidence is earned in practice and spent on the course.",
  "Let the club do the work, you just deliver it.",
  "A relaxed grip travels further than a tight one.",
  "Today's practice is next month's advantage.",
  "Champions are made on days no one is watching.",
  "The green rewards a golfer with a plan.",
  "Smart golf is winning golf.",
  "Your rhythm is your signature. Trust it.",
  "Every round is a fresh scorecard and a fresh mind.",
  "Process over outcome, the scores follow.",
  "You are one good habit away from your best golf.",
  "Slow is smooth, and smooth is far.",
  "Swing free. The ball loves confidence.",
  "Show up. Swing well. Let the rest happen.",
  "Golf rewards the player who stays present."
];

async function load(){
  try { const r = await store.get('golf-sessions'); sessions = r ? JSON.parse(r.value) : []; }
  catch(e){ sessions = []; }
  greet(); weather(); render();
}
async function save(){
  try { await store.set('golf-sessions', JSON.stringify(sessions)); }
  catch(e){ toast('Save failed'); }
}
function greet(){
  const day = Math.floor(Date.now()/86400000);
  document.getElementById('affirm').textContent = '"' + AFFIRM[day % AFFIRM.length] + '"';
}
async function weather(){
  const el = document.getElementById('wx');
  const codes = {0:['\u2600\uFE0F','Clear'],1:['\uD83C\uDF24\uFE0F','Mostly clear'],2:['\u26C5','Partly cloudy'],3:['\u2601\uFE0F','Cloudy'],45:['\uD83C\uDF2B\uFE0F','Fog'],48:['\uD83C\uDF2B\uFE0F','Fog'],51:['\uD83C\uDF26\uFE0F','Drizzle'],53:['\uD83C\uDF26\uFE0F','Drizzle'],55:['\uD83C\uDF26\uFE0F','Drizzle'],61:['\uD83C\uDF27\uFE0F','Light rain'],63:['\uD83C\uDF27\uFE0F','Rain'],65:['\uD83C\uDF27\uFE0F','Heavy rain'],71:['\uD83C\uDF28\uFE0F','Snow'],80:['\uD83C\uDF26\uFE0F','Showers'],81:['\uD83C\uDF27\uFE0F','Showers'],82:['\u26C8\uFE0F','Heavy showers'],95:['\u26C8\uFE0F','Storm'],96:['\u26C8\uFE0F','Storm'],99:['\u26C8\uFE0F','Storm']};
  const show = async (lat,lon)=>{
    try {
      const r = await fetch('https://api.open-meteo.com/v1/forecast?latitude='+lat+'&longitude='+lon+'&current=temperature_2m,weather_code');
      const j = await r.json();
      const c = j.current;
      const pair = codes[c.weather_code] || ['\uD83C\uDF21\uFE0F',''];
      const ds = new Date().toLocaleDateString(undefined,{day:'numeric',month:'short'});
      el.innerHTML = '<div style="font-size:1.5rem;line-height:1;">'+pair[0]+'</div>'+
        '<div style="font-family:var(--disp);font-weight:600;font-size:1.15rem;margin-top:6px;">'+Math.round(c.temperature_2m)+'\u00B0</div>'+
        '<div class="eyebrow" style="margin-top:5px;">'+pair[1]+'</div>'+
        '<div class="eyebrow" style="margin-top:3px;color:var(--faint);">'+ds+'</div>';
      el.style.display = 'block';
    } catch(e){}
  };
  if (navigator.geolocation) navigator.geolocation.getCurrentPosition(p=>show(p.coords.latitude,p.coords.longitude),()=>show(26.91,75.79),{timeout:3000});
  else show(26.91,75.79);
}
function toast(m){ const t=document.getElementById('toast'); t.textContent=m; t.classList.add('show'); setTimeout(()=>t.classList.remove('show'),1800); }
function today(){ return new Date().toISOString().slice(0,10); }
function fmtDate(d){ return new Date(d+'T12:00').toLocaleDateString(undefined,{weekday:'short',month:'short',day:'numeric'}); }
function esc(s){ return (s||'').replace(/[&<>"]/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c])); }
function setTab(t){
  tab=t; expanded=null;
  document.querySelectorAll('.bottomnav button').forEach(b=>b.classList.remove('active'));
  document.getElementById('tab-'+t).classList.add('active');
  render(); window.scrollTo({top:0});
}
function render(){
  const v = document.getElementById('view');
  v.style.animation='none'; void v.offsetWidth; v.style.animation='';
  if (tab==='log') v.innerHTML = renderLog();
  else if (tab==='history') v.innerHTML = renderHistory();
  else v.innerHTML = renderStats();
}

/* ---------- LOG ---------- */
function renderLog(){
  if (!draft) return '<div class="idx">'+
    '<button onclick="startDraft(\'round\')"><span class="no">01</span><span style="flex:1;"><span class="t">Play a Round</span><span class="s">9 or 18 holes / hole by hole</span></span><span class="ar">&rarr;</span></button>'+
    '<button onclick="startDraft(\'putting\')"><span class="no">02</span><span style="flex:1;"><span class="t">Putting Practice</span><span class="s">Make % by distance</span></span><span class="ar">&rarr;</span></button>'+
    '<button onclick="startDraft(\'range\')"><span class="no">03</span><span style="flex:1;"><span class="t">Range Session</span><span class="s">Ball striking by club</span></span><span class="ar">&rarr;</span></button>'+
    '</div>';
  if (draft.type==='round') return draft.review ? renderReview() : renderWizard();
  if (draft.type==='putting') return renderPuttingForm();
  return renderRangeForm();
}
function startDraft(type){
  if (type==='round') draft={type:type,date:today(),course:'',holes:Array.from({length:18},()=>({par:4,score:0,putts:2,fir:null,gir:false,tee:'',note:''})),count:18,cur:-1,review:false,notes:''};
  if (type==='putting') draft={type:type,date:today(),drills:[{dist:'6 ft',att:10,made:0}],notes:''};
  if (type==='range') draft={type:type,date:today(),clubs:[{club:'7i',shots:10,good:0,miss:'Straight'}],notes:''};
  render();
}
function cancelDraft(){ draft=null; render(); toast('Discarded'); }
function setH(i,k,v){ draft.holes[i][k]=v; render(); }
function nextHole(){ draft.cur++; render(); window.scrollTo({top:0,behavior:'smooth'}); }

function renderWizard(){
  if (draft.cur === -1){
    return '<div class="sec">'+
      '<div class="eyebrow grn">01 &mdash; New Round</div>'+
      '<label class="fld">Date</label><input type="date" value="'+draft.date+'" onchange="draft.date=this.value">'+
      '<label class="fld">Golf Course</label><input type="text" placeholder="e.g. Rambagh" value="'+esc(draft.course)+'" onchange="draft.course=this.value">'+
      '<label class="fld">Holes</label><div class="pills">'+
        '<button class="pill '+(draft.count===9?'sel':'')+'" onclick="draft.count=9;render()">9</button>'+
        '<button class="pill '+(draft.count===18?'sel':'')+'" onclick="draft.count=18;render()">18</button>'+
      '</div>'+
      '<div class="wiz-nav"><button class="btn lite" onclick="cancelDraft()">Cancel</button>'+
      '<button class="btn green" onclick="draft.cur=0;render()">Start</button></div></div>';
  }
  const i = draft.cur, h = draft.holes[i];
  const done = draft.holes.slice(0,draft.count).filter(x=>x.score>0);
  const diff = done.reduce((a,x)=>a+x.score,0) - done.reduce((a,x)=>a+x.par,0);
  const names = {'-2':'Eagle','-1':'Birdie','0':'Par','1':'Bogey','2':'Double','3':'Triple'};
  let scoreBtns = '';
  for (let s=Math.max(1,h.par-2); s<=h.par+3; s++){
    const rel = s-h.par;
    scoreBtns += '<button class="pill '+(h.score===s?'grn':'')+'" onclick="setH('+i+',\'score\','+s+')">'+s+'<small>'+(names[rel]||'+'+rel)+'</small></button>';
  }
  let dots = '';
  for (let d=0; d<draft.count; d++) dots += '<i class="'+(draft.holes[d].score>0?'done ':'')+(d===i?'cur':'')+'"></i>';
  return '<div>'+
    '<div class="wiz-head"><div class="hole"><em>Hole</em>'+String(i+1).padStart(2,'0')+'</div>'+
    '<div class="run"><div class="v">'+(done.length ? (diff>0?'+':'')+(diff===0?'E':diff) : 'E')+'</div><div class="k">thru '+done.length+'</div></div></div>'+
    '<div class="dots">'+dots+'</div>'+
    '<label class="fld">Par</label><div class="pills">'+
      [3,4,5].map(p=>'<button class="pill '+(h.par===p?'sel':'')+'" onclick="setH('+i+',\'par\','+p+')">'+p+'</button>').join('')+'</div>'+
    (h.par>3 ? '<label class="fld">Tee Club</label><div class="pills">'+
      TEES.map(t=>'<button class="pill '+(h.tee===t?'sel':'')+'" style="font-size:0.72rem;" onclick="setH('+i+',\'tee\',\''+t+'\')">'+t+'</button>').join('')+'</div>' : '')+
    '<label class="fld">Score</label><div class="pills">'+scoreBtns+'</div>'+
    '<label class="fld">Putts</label><div class="pills">'+
      [0,1,2,3,4].map(p=>'<button class="pill '+(h.putts===p?'sel':'')+'" onclick="setH('+i+',\'putts\','+p+')">'+p+'</button>').join('')+'</div>'+
    '<label class="fld">Off the Tee &amp; Approach</label><div style="display:flex;gap:10px;">'+
      (h.par>3 ? '<button class="tgl2 '+(h.fir?'on':'')+'" onclick="setH('+i+',\'fir\','+(!h.fir)+')">Fairway '+(h.fir?'\u2713':'')+'</button>' : '')+
      '<button class="tgl2 '+(h.gir?'on':'')+'" onclick="setH('+i+',\'gir\','+(!h.gir)+')">Green '+(h.gir?'\u2713':'')+'</button></div>'+
    '<label class="fld">Hole Note</label><input type="text" placeholder="e.g. pushed drive right" value="'+esc(h.note)+'" onchange="draft.holes['+i+'].note=this.value">'+
    '<div class="wiz-nav">'+
      '<button class="btn lite" style="flex:0 0 64px;" onclick="'+(i>0?'draft.cur--':'draft.cur=-1')+';render()">&larr;</button>'+
      (i<draft.count-1 ? '<button class="btn" onclick="nextHole()">Next Hole</button>' : '<button class="btn green" onclick="draft.review=true;render()">Finish</button>')+
    '</div>'+
    '<button class="btn txt" style="width:100%;margin-top:8px;" onclick="draft.review=true;render()">Finish early</button>'+
    '<button class="btn txt" style="width:100%;" onclick="cancelDraft()">Discard round</button>'+
  '</div>';
}

function scGrid(holes, count){
  const half = (from,to)=>{
    const hs = holes.slice(from,to);
    const played = hs.filter(h=>h.score>0);
    const c = {hole:'',par:'',score:'',putts:''};
    hs.forEach((h,idx)=>{
      c.hole += '<th>'+(from+idx+1)+'</th>';
      c.par += '<td>'+h.par+'</td>';
      let cls=''; const rel=h.score-h.par;
      if (h.score>0){ if(rel<0)cls='birdie'; else if(rel===1)cls='bogey'; else if(rel>=2)cls='dbl'; }
      c.score += '<td>'+(h.score>0 ? '<span class="sc-badge '+cls+'">'+h.score+'</span>' : '&ndash;')+'</td>';
      c.putts += '<td>'+(h.score>0 ? h.putts : '&ndash;')+'</td>';
    });
    return {c:c, par:played.reduce((a,h)=>a+h.par,0), score:played.reduce((a,h)=>a+h.score,0), putts:played.reduce((a,h)=>a+h.putts,0)};
  };
  const f = half(0,Math.min(9,count));
  const b = count>9 ? half(9,18) : null;
  const tS=f.score+(b?b.score:0), tP=f.par+(b?b.par:0), tPt=f.putts+(b?b.putts:0);
  return '<div class="sc-scroll"><table class="sc"><thead><tr><th style="text-align:left;">Hole</th>'+f.c.hole+'<th>Out</th>'+(b?b.c.hole+'<th>In</th>':'')+'<th>Tot</th></tr></thead><tbody>'+
    '<tr><th>Par</th>'+f.c.par+'<td class="tot">'+f.par+'</td>'+(b?b.c.par+'<td class="tot">'+b.par+'</td>':'')+'<td class="tot">'+tP+'</td></tr>'+
    '<tr><th>Score</th>'+f.c.score+'<td class="tot">'+(f.score||'&ndash;')+'</td>'+(b?b.c.score+'<td class="tot">'+(b.score||'&ndash;')+'</td>':'')+'<td class="tot">'+(tS||'&ndash;')+'</td></tr>'+
    '<tr><th>Putts</th>'+f.c.putts+'<td class="tot">'+f.putts+'</td>'+(b?b.c.putts+'<td class="tot">'+b.putts+'</td>':'')+'<td class="tot">'+tPt+'</td></tr>'+
    '</tbody></table></div>';
}
function holeNotes(holes){
  const rows = holes.map((h,i)=> h.note ? '<div class="coach"><span class="no">H'+(i+1)+'</span><p>'+esc(h.note)+'</p></div>' : '').filter(Boolean);
  return rows.length ? '<div style="margin-top:18px;"><div class="eyebrow">Hole Notes</div>'+rows.join('')+'</div>' : '';
}
function radar(vals, bench){
  const cx=150, cy=132, R=96;
  const pt = (i,v)=>{ const a=[-90,0,90,180][i]*Math.PI/180; return (cx+Math.cos(a)*R*v)+','+(cy+Math.sin(a)*R*v); };
  const poly = a=>a.map((v,i)=>pt(i,Math.max(.04,Math.min(1,v)))).join(' ');
  const ring = f=>'<polygon points="'+[0,1,2,3].map(i=>pt(i,f)).join(' ')+'" fill="none" stroke="rgba(255,255,255,.08)" stroke-width="1"/>';
  const L = 'font-family="IBM Plex Mono, monospace" font-size="8.5" font-weight="600" letter-spacing="1.5" fill="#9a988f"';
  return '<div class="radar-wrap"><svg width="300" height="264" viewBox="0 0 300 264" xmlns="http://www.w3.org/2000/svg">'+
    ring(1)+ring(.66)+ring(.33)+
    '<line x1="'+cx+'" y1="'+(cy-R)+'" x2="'+cx+'" y2="'+(cy+R)+'" stroke="rgba(255,255,255,.08)"/>'+
    '<line x1="'+(cx-R)+'" y1="'+cy+'" x2="'+(cx+R)+'" y2="'+cy+'" stroke="rgba(255,255,255,.08)"/>'+
    '<polygon points="'+poly(bench)+'" fill="none" stroke="rgba(255,255,255,.28)" stroke-width="1.2" stroke-dasharray="3 4"/>'+
    '<polygon points="'+poly(vals)+'" fill="rgba(87,201,141,.13)" stroke="#57c98d" stroke-width="1.8"/>'+
    vals.map((v,i)=>{ const xy = pt(i,Math.max(.04,Math.min(1,v))).split(','); return '<circle cx="'+xy[0]+'" cy="'+xy[1]+'" r="3.2" fill="#57c98d"/>'; }).join('')+
    '<text x="'+cx+'" y="'+(cy-R-12)+'" text-anchor="middle" '+L+'>OFF THE TEE</text>'+
    '<text x="'+(cx+R+8)+'" y="'+(cy+3)+'" text-anchor="start" '+L+'>APPR</text>'+
    '<text x="'+cx+'" y="'+(cy+R+18)+'" text-anchor="middle" '+L+'>SHORT GAME</text>'+
    '<text x="'+(cx-R-8)+'" y="'+(cy+3)+'" text-anchor="end" '+L+'>PUTT</text>'+
    '</svg></div>'+
    '<div style="display:flex;gap:18px;justify-content:center;margin-top:2px;">'+
    '<span class="eyebrow" style="color:var(--green);">&mdash; You</span><span class="eyebrow">- - Tour avg</span></div>';
}
function gapPill(val, bench, higherBetter, suffix){
  if (higherBetter === undefined) higherBetter = true;
  if (suffix === undefined) suffix = '%';
  const diff = val - bench;
  const good = higherBetter ? diff>=0 : diff<=0;
  const shown = Math.abs(diff).toFixed(suffix==='%' ? 0 : 2);
  return '<span class="gap '+(good?'up':'dn')+'">'+(good?'+':'\u2212')+shown+suffix+'</span>';
}
function roundSummary(played){
  if (played.length < 6) return '';
  let girH=0, firH=0, firT=0, scrA=0, scrM=0, tPt=0;
  played.forEach(h=>{
    if (h.gir) girH++;
    if (h.par>3){ firT++; if(h.fir) firH++; }
    if (!h.gir){ scrA++; if(h.score<=h.par) scrM++; }
    tPt += h.putts;
  });
  const gir=girH/played.length*100, fir=firT?firH/firT*100:0, scr=scrA?scrM/scrA*100:0, pph=tPt/played.length;
  const vals=[fir/100, gir/100, scr/100, Math.max(0,Math.min(1,(2.3-pph)/0.9))];
  const bench=[0.60,0.65,0.58,(2.3-1.60)/0.9];
  return '<div style="margin-top:24px;"><div class="eyebrow">This Round &mdash; Game Shape</div>'+radar(vals,bench)+
    '<div class="bench"><div class="n">Off the Tee<small>Tour 60%</small></div><div class="r"><span class="v">'+Math.round(fir)+'%</span>'+gapPill(fir,60)+'</div></div>'+
    '<div class="bench"><div class="n">Approaches<small>Tour 65%</small></div><div class="r"><span class="v">'+Math.round(gir)+'%</span>'+gapPill(gir,65)+'</div></div>'+
    '<div class="bench"><div class="n">Short Game<small>Tour 58%</small></div><div class="r"><span class="v">'+Math.round(scr)+'%</span>'+gapPill(scr,58)+'</div></div>'+
    '<div class="bench"><div class="n">Putting<small>Tour 1.60 / hole</small></div><div class="r"><span class="v">'+pph.toFixed(2)+'</span>'+gapPill(pph,1.60,false,'')+'</div></div></div>';
}
function renderReview(){
  const played = draft.holes.slice(0,draft.count).filter(h=>h.score>0);
  if (!played.length){ draft.review=false; toast('No scores yet'); return renderWizard(); }
  const s = played.reduce((a,h)=>a+h.score,0), p = played.reduce((a,h)=>a+h.par,0), d = s-p;
  return '<div><div class="eyebrow grn">Scorecard &mdash; '+(esc(draft.course)||'Round')+' / '+fmtDate(draft.date)+'</div>'+
    '<div style="display:flex;align-items:baseline;gap:14px;margin:16px 0 22px;">'+
      '<span style="font-family:var(--disp);font-size:3.4rem;font-weight:600;letter-spacing:-0.04em;line-height:1;">'+s+'</span>'+
      '<span style="font-size:1.2rem;font-weight:800;color:'+(d<=0?'var(--green)':'var(--red)')+'">'+(d>0?'+':'')+(d===0?'E':d)+'</span>'+
      '<span class="eyebrow">'+played.length+' holes</span></div>'+
    scGrid(draft.holes, draft.count)+
    roundSummary(played)+
    holeNotes(draft.holes)+
    '<label class="fld">Round Notes</label><textarea placeholder="What worked? What did not?" onchange="draft.notes=this.value">'+esc(draft.notes)+'</textarea>'+
    '<div class="wiz-nav"><button class="btn lite" onclick="draft.review=false;render()">Edit</button>'+
    '<button class="btn green" onclick="saveDraft()">Save Round</button></div>'+
    '<button class="btn txt" style="width:100%;margin-top:8px;" onclick="cancelDraft()">Discard</button></div>';
}

function renderPuttingForm(){
  const rows = draft.drills.map((d,i)=>
    '<div class="entry-row">'+
    '<select style="flex:1;min-width:90px;width:auto;" onchange="draft.drills['+i+'].dist=this.value">'+
      DISTS.map(x=>'<option '+(d.dist===x?'selected':'')+'>'+x+'</option>').join('')+'</select>'+
    '<div><div class="mini-lbl">Attempts</div><div class="stepper"><button onclick="pb('+i+',\'att\',-1)">\u2212</button><span>'+d.att+'</span><button onclick="pb('+i+',\'att\',1)">+</button></div></div>'+
    '<div><div class="mini-lbl">Made</div><div class="stepper"><button onclick="pb('+i+',\'made\',-1)">\u2212</button><span>'+d.made+'</span><button onclick="pb('+i+',\'made\',1)">+</button></div></div>'+
    '</div>').join('');
  return '<div class="sec"><div class="eyebrow grn">02 &mdash; Putting Practice</div>'+
    '<label class="fld">Date</label><input type="date" value="'+draft.date+'" onchange="draft.date=this.value">'+
    '<div style="margin-top:14px;">'+rows+'</div>'+
    '<button class="btn txt" style="width:100%;text-align:left;color:var(--green);padding-left:0;" onclick="draft.drills.push({dist:\'10 ft\',att:10,made:0});render()">+ Add distance</button>'+
    '<label class="fld">Notes</label><textarea placeholder="Green speed, stroke feel" onchange="draft.notes=this.value">'+esc(draft.notes)+'</textarea>'+
    '<div class="wiz-nav"><button class="btn lite" onclick="cancelDraft()">Discard</button>'+
    '<button class="btn green" onclick="saveDraft()">Save</button></div></div>';
}
function pb(i,k,d){ const dr=draft.drills[i]; dr[k]=Math.max(0,dr[k]+d); if(dr.made>dr.att)dr.made=dr.att; render(); }

function renderRangeForm(){
  const rows = draft.clubs.map((c,i)=>
    '<div class="entry-row">'+
    '<select style="flex:1;min-width:90px;width:auto;" onchange="draft.clubs['+i+'].club=this.value">'+
      CLUBS.map(x=>'<option '+(c.club===x?'selected':'')+'>'+x+'</option>').join('')+'</select>'+
    '<div><div class="mini-lbl">Shots</div><div class="stepper"><button onclick="rb('+i+',\'shots\',-1)">\u2212</button><span>'+c.shots+'</span><button onclick="rb('+i+',\'shots\',1)">+</button></div></div>'+
    '<div><div class="mini-lbl">Good</div><div class="stepper"><button onclick="rb('+i+',\'good\',-1)">\u2212</button><span>'+c.good+'</span><button onclick="rb('+i+',\'good\',1)">+</button></div></div>'+
    '<div style="width:100%;"><div class="mini-lbl" style="text-align:left;">Main miss</div><div class="pills" style="margin-top:5px;">'+
      MISSES.map(m=>'<button class="pill '+(c.miss===m?'sel':'')+'" style="font-size:0.68rem;padding:9px 0;" onclick="draft.clubs['+i+'].miss=\''+m+'\';render()">'+m+'</button>').join('')+
    '</div></div></div>').join('');
  return '<div class="sec"><div class="eyebrow grn">03 &mdash; Range Session</div>'+
    '<label class="fld">Date</label><input type="date" value="'+draft.date+'" onchange="draft.date=this.value">'+
    '<div style="margin-top:14px;">'+rows+'</div>'+
    '<button class="btn txt" style="width:100%;text-align:left;color:var(--green);padding-left:0;" onclick="draft.clubs.push({club:\'Driver\',shots:10,good:0,miss:\'Straight\'});render()">+ Add club</button>'+
    '<label class="fld">Notes</label><textarea placeholder="Swing thought, contact" onchange="draft.notes=this.value">'+esc(draft.notes)+'</textarea>'+
    '<div class="wiz-nav"><button class="btn lite" onclick="cancelDraft()">Discard</button>'+
    '<button class="btn green" onclick="saveDraft()">Save</button></div></div>';
}
function rb(i,k,d){ const c=draft.clubs[i]; c[k]=Math.max(0,c[k]+d); if(c.good>c.shots)c.good=c.shots; render(); }

async function saveDraft(){
  if (draft.type==='round'){
    draft.holes = draft.holes.slice(0,draft.count);
    if (draft.holes.every(h=>!h.score)){ toast('Enter at least one score'); return; }
  }
  draft.id = Date.now();
  delete draft.cur; delete draft.review;
  sessions.unshift(draft);
  draft = null;
  await save(); toast('Saved'); setTab('history');
}

/* ---------- HISTORY ---------- */
function summarize(s){
  if (s.type==='round'){
    const p = s.holes.filter(h=>h.score>0);
    const sc = p.reduce((a,h)=>a+h.score,0), pr = p.reduce((a,h)=>a+h.par,0), d = sc-pr;
    return {big: sc, sub: (d>0?'+':'')+(d===0?'E':d)+' / '+p.length+'h'};
  }
  if (s.type==='putting'){
    const att = s.drills.reduce((a,d)=>a+d.att,0), made = s.drills.reduce((a,d)=>a+d.made,0);
    return {big: att ? Math.round(made/att*100)+'%' : '-', sub: made+'/'+att};
  }
  const shots = s.clubs.reduce((a,c)=>a+c.shots,0), good = s.clubs.reduce((a,c)=>a+c.good,0);
  return {big: shots ? Math.round(good/shots*100)+'%' : '-', sub: shots+' balls'};
}
function renderHistory(){
  if (!sessions.length) return '<div class="empty">Nothing logged yet.<br>Your card is waiting.</div>';
  const names = {round:'Round', putting:'Putting', range:'Range'};
  const courses = [];
  sessions.forEach(s=>{ if(s.course && courses.indexOf(s.course)<0) courses.push(s.course); });
  let filterHtml = '';
  if (courses.length){
    filterHtml = '<div style="margin-bottom:10px;"><select onchange="courseFilter=this.value;render()">'+
      '<option value="all" '+(courseFilter==='all'?'selected':'')+'>All sessions</option>'+
      courses.map(c=>'<option value="'+esc(c)+'" '+(courseFilter===c?'selected':'')+'>'+esc(c)+'</option>').join('')+'</select></div>';
  }
  const shown = courseFilter==='all' ? sessions : sessions.filter(s=>s.course===courseFilter);
  if (!shown.length) return filterHtml + '<div class="empty">No sessions for this course.</div>';
  return filterHtml + shown.map(s=>{
    const sum = summarize(s);
    const det = (expanded===s.id && s.type==='round') ? '<div class="sess-detail">'+scGrid(s.holes,s.holes.length)+holeNotes(s.holes)+'</div>' : '';
    return '<div class="sess" onclick="toggleSess('+s.id+')">'+
      '<div class="l"><div class="t">'+names[s.type]+'</div><div class="d">'+fmtDate(s.date)+(s.course?' / '+esc(s.course):'')+'</div>'+
      (s.notes?'<div class="n">"'+esc(s.notes)+'"</div>':'')+'</div>'+
      '<div class="r"><div><div class="big">'+sum.big+'</div><div class="subv">'+sum.sub+'</div></div>'+
      '<button class="del" onclick="event.stopPropagation();delSess('+s.id+')">\u2715</button></div></div>'+det;
  }).join('');
}
function toggleSess(id){ expanded = expanded===id ? null : id; render(); }
async function delSess(id){ sessions = sessions.filter(s=>s.id!==id); await save(); render(); toast('Deleted'); }

/* ---------- STATS ---------- */
function renderStats(){
  if (!sessions.length) return '<div class="empty">Stats appear once sessions are logged.</div>';
  const rounds = sessions.filter(s=>s.type==='round');
  const putts = sessions.filter(s=>s.type==='putting');
  const ranges = sessions.filter(s=>s.type==='range');
  let html = '', coach = [];

  const days = [];
  sessions.forEach(s=>{ if(days.indexOf(s.date)<0) days.push(s.date); });
  const ym = new Date().toISOString().slice(0,7);
  const thisMonth = days.filter(d=>d.indexOf(ym)===0).length;
  let streak = 0;
  {
    let cur = new Date();
    const set = {};
    days.forEach(d=>set[d]=1);
    if (!set[cur.toISOString().slice(0,10)]) cur.setDate(cur.getDate()-1);
    while (set[cur.toISOString().slice(0,10)]){ streak++; cur.setDate(cur.getDate()-1); }
  }
  html += '<div class="sec"><div class="eyebrow">Consistency</div><div class="bignum-row" style="margin-top:16px;">'+
    '<div class="bignum"><div class="v">'+days.length+'</div><div class="k">Days<br>Practiced</div></div>'+
    '<div class="bignum"><div class="v">'+thisMonth+'</div><div class="k">This<br>Month</div></div>'+
    '<div class="bignum"><div class="v'+(streak>2?' grn':'')+'">'+streak+'</div><div class="k">Day<br>Streak</div></div>'+
    '<div class="bignum"><div class="v">'+sessions.length+'</div><div class="k">Total<br>Sessions</div></div></div></div>';

  if (rounds.length){
    let tS=0,tP=0,tPt=0,girH=0,girT=0,firH=0,firT=0,three=0,N=0,dbl=0,girBird=0,scrAtt=0,scrMade=0;
    let drvT=0,drvH=0,othT=0,othH=0;
    const parType = {3:{s:0,p:0,n:0,g:0,b:0},4:{s:0,p:0,n:0,g:0,b:0},5:{s:0,p:0,n:0,g:0,b:0}};
    let fS=0,fP=0,fN=0,bS=0,bP=0,bN=0;
    rounds.forEach(r=>r.holes.forEach((h,idx)=>{
      if (!(h.score>0)) return;
      tS+=h.score; tP+=h.par; tPt+=h.putts; N++;
      girT++; if (h.gir){ girH++; if (h.score<h.par) girBird++; }
      if (!h.gir){ scrAtt++; if (h.score<=h.par) scrMade++; }
      if (h.par>3){ firT++; if (h.fir) firH++;
        if (h.tee){ if (h.tee==='Driver'){ drvT++; if(h.fir) drvH++; } else { othT++; if(h.fir) othH++; } } }
      if (h.putts>=3) three++;
      if (h.score-h.par>=2) dbl++;
      const pt = parType[h.par];
      if (pt){ pt.s+=h.score; pt.p+=h.par; pt.n++; if(h.gir)pt.g++; if(h.score<h.par)pt.b++; }
      if (idx<9){ fS+=h.score; fP+=h.par; fN++; } else { bS+=h.score; bP+=h.par; bN++; }
    }));
    const gir = girT?girH/girT*100:0, fir = firT?firH/firT*100:0;
    const scr = scrAtt?scrMade/scrAtt*100:0, pph = N?tPt/N:0, tpr = N?three/N*100:0;
    const avgVsPar = (tS-tP)/rounds.length;

    const vals = [fir/100, gir/100, scr/100, Math.max(0,Math.min(1,(2.3-pph)/0.9))];
    const bench = [0.60, 0.65, 0.58, (2.3-1.60)/0.9];
    html += '<div class="sec"><div class="eyebrow">Game Shape &mdash; '+rounds.length+' rounds</div>'+radar(vals,bench)+'</div>';

    html += '<div class="sec"><div class="eyebrow">You vs Tour Average</div><div style="margin-top:8px;">'+
      '<div class="bench"><div class="n">Greens in Regulation<small>Tour 65%</small></div><div class="r"><span class="v">'+Math.round(gir)+'%</span>'+gapPill(gir,65)+'</div></div>'+
      '<div class="bench"><div class="n">Fairways Hit<small>Tour 60%</small></div><div class="r"><span class="v">'+Math.round(fir)+'%</span>'+gapPill(fir,60)+'</div></div>'+
      '<div class="bench"><div class="n">Putts per Hole<small>Tour 1.60</small></div><div class="r"><span class="v">'+pph.toFixed(2)+'</span>'+gapPill(pph,1.60,false,'')+'</div></div>'+
      '<div class="bench"><div class="n">Three-Putt Rate<small>Tour 3%</small></div><div class="r"><span class="v">'+Math.round(tpr)+'%</span>'+gapPill(tpr,3,false)+'</div></div>'+
      '<div class="bench"><div class="n">Scrambling<small>Tour 58%</small></div><div class="r"><span class="v">'+Math.round(scr)+'%</span>'+gapPill(scr,58)+'</div></div>'+
      '</div><div class="eyebrow" style="margin-top:14px;color:var(--faint);">Tour numbers are approximate PGA averages</div></div>';

    let parRows = '';
    [3,4,5].forEach(p=>{
      const d = parType[p]; if (!d.n) return;
      const avg = d.s/d.n, girP = d.g/d.n*100, birdP = d.b/d.n*100;
      parRows += '<div class="eyebrow" style="margin:22px 0 4px;color:var(--faint);">Par '+p+'s &mdash; '+d.n+' holes</div>'+
        '<div class="bench"><div class="n">Average Score<small>PGA '+PGA[p].avg.toFixed(2)+'</small></div><div class="r"><span class="v">'+avg.toFixed(2)+'</span>'+gapPill(avg,PGA[p].avg,false,'')+'</div></div>'+
        '<div class="bench"><div class="n">GIR<small>PGA '+PGA[p].gir+'%</small></div><div class="r"><span class="v">'+Math.round(girP)+'%</span>'+gapPill(girP,PGA[p].gir)+'</div></div>'+
        '<div class="bench"><div class="n">Birdie or Better<small>PGA '+PGA[p].bird+'%</small></div><div class="r"><span class="v">'+Math.round(birdP)+'%</span>'+gapPill(birdP,PGA[p].bird)+'</div></div>';
    });
    if (parRows) html += '<div class="sec"><div class="eyebrow">By Par Type vs PGA</div>'+parRows+'</div>';

    if (drvT+othT >= 5){
      const dPct = drvT ? Math.round(drvH/drvT*100) : null;
      const oPct = othT ? Math.round(othH/othT*100) : null;
      html += '<div class="sec"><div class="eyebrow">Off the Tee</div><div class="bignum-row" style="margin-top:16px;">'+
        (dPct!==null?'<div class="bignum"><div class="v">'+dPct+'%</div><div class="k">Fairways<br>with Driver</div></div>':'')+
        (oPct!==null?'<div class="bignum"><div class="v">'+oPct+'%</div><div class="k">Fairways<br>Wood / Iron</div></div>':'')+
        '</div></div>';
      if (dPct!==null && oPct!==null && drvT>=5 && oPct-dPct>=20)
        coach.push('Fairways: <b>'+dPct+'% with driver vs '+oPct+'% without</b>. On tight holes the 3-wood is the smarter play right now, and driver dispersion is worth range time.');
    }

    html += '<div class="sec"><div class="eyebrow">Scoring</div><div class="bignum-row" style="margin-top:16px;">'+
      '<div class="bignum"><div class="v">'+(avgVsPar>0?'+':'')+avgVsPar.toFixed(1)+'</div><div class="k">Avg vs Par<br>per Round</div></div>'+
      '<div class="bignum"><div class="v">'+(dbl/rounds.length).toFixed(1)+'</div><div class="k">Doubles+<br>per Round</div></div>'+
      '</div><div style="margin-top:22px;">';
    [3,4,5].forEach(p=>{
      const d = parType[p]; if (!d.n) return;
      const avg = (d.s-d.p)/d.n;
      const pct = Math.min(100, Math.max(5, 100 - avg*55));
      const col = avg<=0.3 ? 'var(--green)' : (avg<=0.6 ? '#d8b25c' : 'var(--red)');
      html += '<div class="hbar"><div class="lbl"><span>Par '+p+'s</span><span>'+(avg>0?'+':'')+avg.toFixed(2)+'</span></div>'+
        '<div class="trk"><div class="fil" style="width:'+pct+'%;background:'+col+'"></div></div></div>';
    });
    html += '</div>';
    const last = rounds.slice(0,7).reverse();
    if (last.length>1){
      const diffs = last.map(r=>{ const p=r.holes.filter(h=>h.score>0); return p.reduce((a,h)=>a+h.score,0)-p.reduce((a,h)=>a+h.par,0); });
      const max = Math.max.apply(null, diffs.map(Math.abs).concat([1]));
      html += '<div style="margin-top:28px;"><div class="eyebrow">Recent rounds vs par</div><div class="bars">'+
        diffs.map(d=>{ const col = d<=0?'var(--green)':'var(--red)';
          return '<div class="b" style="height:'+Math.max(6,Math.abs(d)/max*100)+'%;background:'+col+'"><span style="color:'+col+'">'+(d>0?'+':'')+d+'</span></div>'; }).join('')+
        '</div></div>';
    }
    html += '</div>';

    const cands = [3,4,5].filter(p=>parType[p].n>=3);
    if (cands.length){
      cands.sort((a,b)=>((parType[b].s-parType[b].p)/parType[b].n)-((parType[a].s-parType[a].p)/parType[a].n));
      const w = cands[0];
      const tips = {3:'Tee-shot distance control is the fix. Range work with mid and short irons to exact yardages.',
                    4:'Usually tee shots. Check fairway % and the driver miss pattern.',
                    5:'These should be scoring holes. Lay-up and wedge distances need attention.'};
      coach.push('<b>Par '+w+'s</b> are the weakest hole type (+'+((parType[w].s-parType[w].p)/parType[w].n).toFixed(2)+' per hole). '+tips[w]);
    }
    if (tpr > 12) coach.push('<b>'+Math.round(tpr)+'% three-putt rate</b> is high. Lag putting from 20+ ft is the fastest fix: aim for a 3-ft circle, not the hole.');
    if (girT && gir>=35 && girH && girBird/girH<0.2) coach.push('Hitting greens but <b>converting only '+Math.round(girBird/girH*100)+'% into birdies</b>. Putting inside 10 ft is where those strokes are hiding.');
    if (scrAtt>=5 && scr<30) coach.push('<b>Scrambling '+Math.round(scr)+'%</b>. When the green is missed, par rarely gets saved. Chipping and pitching protect the score.');
    if (dbl/rounds.length >= 2) coach.push('Averaging <b>'+(dbl/rounds.length).toFixed(1)+' doubles-or-worse per round</b>. Big numbers, not missed pars, are inflating scores.');
    if (fN>3 && bN>3){
      const fAvg=(fS-fP)/fN, bAvg=(bS-bP)/bN;
      if (bAvg-fAvg > 0.25) coach.push('<b>Back nine drop-off</b>: '+((bAvg-fAvg)*9).toFixed(1)+' strokes more than the front. Focus, fitness, or food.');
    }
  }

  if (putts.length){
    const byDist = {};
    putts.forEach(s=>s.drills.forEach(d=>{ if(!byDist[d.dist]) byDist[d.dist]={att:0,made:0}; byDist[d.dist].att+=d.att; byDist[d.dist].made+=d.made; }));
    html += '<div class="sec"><div class="eyebrow">Putting &mdash; Make %</div><div style="margin-top:12px;">'+
      DISTS.filter(d=>byDist[d]).map(d=>{
        const p = byDist[d].att ? Math.round(byDist[d].made/byDist[d].att*100) : 0;
        return '<div class="hbar"><div class="lbl"><span>'+d+'</span><span>'+p+'% / '+byDist[d].made+'-'+byDist[d].att+'</span></div>'+
          '<div class="trk"><div class="fil" style="width:'+p+'%"></div></div></div>';
      }).join('')+'</div></div>';
    const short = byDist['3 ft'];
    if (short && short.att>=20 && short.made/short.att<0.85) coach.push('<b>3-footers at '+Math.round(short.made/short.att*100)+'%</b>. Tour players make about 99%. Ten minutes of short putts every session until automatic.');
  }

  if (ranges.length){
    const byClub = {}, missCount = {};
    ranges.forEach(s=>s.clubs.forEach(c=>{
      if(!byClub[c.club]) byClub[c.club]={shots:0,good:0};
      byClub[c.club].shots+=c.shots; byClub[c.club].good+=c.good;
      if (c.miss!=='Straight') missCount[c.miss] = (missCount[c.miss]||0)+(c.shots-c.good);
    }));
    const clubs = Object.keys(byClub).sort((a,b)=>CLUBS.indexOf(a)-CLUBS.indexOf(b));
    html += '<div class="sec"><div class="eyebrow">Range &mdash; Strike Quality</div><div style="margin-top:12px;">'+
      clubs.map(c=>{
        const p = byClub[c].shots ? Math.round(byClub[c].good/byClub[c].shots*100) : 0;
        return '<div class="hbar"><div class="lbl"><span>'+c+'</span><span>'+p+'%</span></div>'+
          '<div class="trk"><div class="fil" style="width:'+p+'%"></div></div></div>';
      }).join('')+'</div></div>';
    const misses = Object.keys(missCount).sort((a,b)=>missCount[b]-missCount[a]);
    if (misses.length && missCount[misses[0]]>=5) coach.push('Dominant range miss: <b>'+misses[0]+'</b>. One consistent miss is fixable and usually points to a single setup or path issue.');
    const heavy = clubs.filter(c=>byClub[c].shots>=15).sort((a,b)=>(byClub[a].good/byClub[a].shots)-(byClub[b].good/byClub[b].shots));
    if (heavy.length) coach.push('Lowest strike quality: <b>'+heavy[0]+'</b> ('+Math.round(byClub[heavy[0]].good/byClub[heavy[0]].shots*100)+'%). Give it the first 15 balls of the next bucket, not the last.');
  }

  if (sessions.length>=5 && rounds.length){
    const pMix = putts.length/sessions.length;
    let tPt=0, N=0;
    rounds.forEach(r=>r.holes.forEach(h=>{ if(h.score>0){ tPt+=h.putts; N++; } }));
    if (N && tPt/N>1.9 && pMix<0.25) coach.push('Putting is <b>'+(tPt/N).toFixed(2)+' per hole</b> but only '+Math.round(pMix*100)+'% of practice time. The data says flip that ratio.');
  }

  if (coach.length) html += '<div class="sec"><div class="eyebrow">Coach\u2019s Notes</div><div style="margin-top:6px;">'+
    coach.map((c,i)=>'<div class="coach"><span class="no">'+String(i+1).padStart(2,'0')+'</span><p>'+c+'</p></div>').join('')+'</div></div>';
  return html;
}
load();

</script>
</body>
</html>
