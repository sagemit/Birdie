      <div style="display:flex;align-items:flex-end;gap:10px;margin-top:30px;"><h1 id="hi" style="margin-top:0;">Hi, Mano.</h1><span style="font-size:1.7rem;line-height:1;margin-bottom:3px;">🏌️</span></div>
