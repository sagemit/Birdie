<link rel="manifest" href='data:application/manifest+json,{"name":"Birdie","short_name":"Birdie","display":"standalone","start_url":".","background_color":"%230e0e0e","theme_color":"%230e0e0e"}'>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@500;600&family=Cal+Sans&display=swap" rel="stylesheet">
<style>
  :root {
    --bg:#0e0e0e; --card:#171716; --ink:#f5f5f3; --sub:#9a988f; --faint:#54524c;
    --green:#57c98d; --red:#e0705a; --lav:#b9bef5;
    --disp:'Cal Sans','Helvetica Neue',Helvetica,sans-serif;
    --hair:rgba(255,255,255,.09); --hair2:rgba(255,255,255,.05);
    --green-soft:rgba(87,201,141,.13); --red-soft:rgba(224,112,90,.14);
  }
  * { margin:0; padding:0; box-sizing:border-box; -webkit-tap-highlight-color:transparent; }
  body {
    font-family:'Helvetica Neue',Helvetica,Arial,sans-serif; background:var(--bg); color:var(--ink); min-height:100vh;
    background-image: radial-gradient(rgba(255,255,255,.045) 1px, transparent 1px);
    background-size: 24px 24px;
  }
  .wrap { max-width:430px; margin:0 auto; padding:30px 24px 130px; position:relative; z-index:1; }
  #topo { position:fixed; inset:0; width:100%; height:100%; pointer-events:none; z-index:0; opacity:.4; }

  .eyebrow { font-family:'IBM Plex Mono',ui-monospace,monospace; font-size:0.6rem; font-weight:600; letter-spacing:0.22em; text-transform:uppercase; color:var(--sub); }
  .eyebrow.grn { color:var(--green); }

  header { padding:4px 0 26px; display:flex; justify-content:space-between; align-items:flex-start; gap:14px; }
  header h1 { font-family:var(--disp); font-weight:600; font-size:2.7rem; letter-spacing:-0.03em; line-height:1; margin-top:30px; }
  header .sub { color:var(--sub); font-size:0.9rem; margin-top:10px; font-weight:500; }
  .affirm { font-family:'IBM Plex Mono',monospace; font-size:0.66rem; color:var(--sub); margin-top:16px; line-height:1.8; letter-spacing:0.05em; text-transform:uppercase; }
  #wx { display:none; text-align:right; flex-shrink:0; padding-top:4px; }

  .bottomnav { position:fixed; bottom:0; left:0; right:0; z-index:50; background:rgba(14,14,14,.92); backdrop-filter:blur(14px); -webkit-backdrop-filter:blur(14px); border-top:1px solid var(--hair); }
  .bottomnav .inner { max-width:430px; margin:0 auto; display:flex; padding:10px 24px calc(12px + env(safe-area-inset-bottom)); }
  .bottomnav button { flex:1; background:none; border:none; cursor:pointer; display:flex; flex-direction:column; align-items:center; gap:6px; color:var(--faint); transition:color .15s; padding:4px 0; }
  .bottomnav button svg { width:21px; height:21px; stroke:currentColor; fill:none; stroke-width:1.8; stroke-linecap:round; stroke-linejoin:round; }
  .bottomnav button .bl { font-family:'IBM Plex Mono',monospace; font-size:0.5rem; font-weight:600; letter-spacing:0.18em; text-transform:uppercase; }
  .bottomnav button.active { color:var(--green); }
  #view { animation:pagein .22s ease; }
  @keyframes pagein { from { opacity:0; transform:translateY(6px); } to { opacity:1; transform:none; } }

  .idx { border-top:1px solid var(--hair); }
  .idx button { width:100%; display:flex; align-items:center; gap:18px; padding:28px 2px; background:none; border:none; border-bottom:1px solid var(--hair); cursor:pointer; font-family:inherit; text-align:left; }
  .idx .no { font-family:'IBM Plex Mono',monospace; font-size:0.62rem; font-weight:600; color:var(--faint); letter-spacing:0.12em; width:26px; }
  .idx .t { font-family:var(--disp); font-size:1.5rem; font-weight:600; letter-spacing:-0.02em; color:#e2e0da; flex:1; transition:color .15s; }
  .idx .s { display:block; font-family:'IBM Plex Mono',monospace; font-size:0.58rem; font-weight:500; color:var(--sub); letter-spacing:0.1em; text-transform:uppercase; margin-top:8px; }
  .idx .ar { color:var(--faint); font-size:1.1rem; transition:all .15s; }
  .idx button:active .t { color:var(--ink); }
  .idx button:active .ar { color:var(--green); transform:translateX(3px); }

  .sec { border-top:1px solid var(--hair); padding:24px 0 28px; }
  .sec:first-child { border-top:none; padding-top:0; }

  label.fld { display:block; font-family:'IBM Plex Mono',monospace; font-size:0.56rem; font-weight:600; letter-spacing:0.2em; text-transform:uppercase; color:var(--sub); margin:20px 0 8px; }
  input[type=text], input[type=date], select, textarea { width:100%; padding:14px; border:1px solid var(--hair); border-radius:12px; background:var(--card); font-family:inherit; font-size:1rem; font-weight:600; color:var(--ink); appearance:none; }
  input:focus, select:focus, textarea:focus { outline:none; border-color:var(--green); }
  select option { background:#1d1d1c; color:var(--ink); }
  textarea { resize:vertical; min-height:56px; font-weight:500; line-height:1.5; }
  ::placeholder { color:var(--faint); }

  .pills { display:flex; gap:8px; flex-wrap:wrap; }
  .pill { padding:13px 0; flex:1; min-width:44px; border:1px solid var(--hair); background:var(--card); border-radius:12px; font-family:inherit; font-size:1.05rem; font-weight:800; letter-spacing:-0.02em; color:var(--sub); cursor:pointer; text-align:center; transition:all .12s; }
  .pill.sel { border-color:var(--ink); color:#0e0e0e; background:var(--ink); }
  .pill.grn { border-color:var(--green); color:#0e1f15; background:var(--green); }
  .pill small { display:block; font-family:'IBM Plex Mono',monospace; font-size:0.48rem; font-weight:600; letter-spacing:0.08em; text-transform:uppercase; opacity:.75; margin-top:3px; }
  .tgl2 { flex:1; padding:15px 0; border:1px solid var(--hair); background:var(--card); border-radius:12px; font-family:'IBM Plex Mono',monospace; font-size:0.6rem; font-weight:600; letter-spacing:0.12em; text-transform:uppercase; color:var(--faint); cursor:pointer; transition:all .12s; }
  .tgl2.on { border-color:var(--green); color:var(--green); background:var(--green-soft); }

  .wiz-head { display:flex; align-items:flex-end; justify-content:space-between; }
  .wiz-head .hole { font-family:var(--disp); font-weight:600; font-size:3.2rem; letter-spacing:-0.04em; line-height:0.95; }
  .wiz-head .hole em { font-style:normal; font-family:'IBM Plex Mono',monospace; font-size:0.6rem; color:var(--faint); font-weight:600; letter-spacing:0.22em; text-transform:uppercase; display:block; margin-bottom:10px; }
  .wiz-head .run { text-align:right; padding-bottom:4px; }
  .wiz-head .run .v { font-family:var(--disp); font-size:2rem; font-weight:600; letter-spacing:-0.02em; }
  .wiz-head .run .k { font-family:'IBM Plex Mono',monospace; font-size:0.54rem; font-weight:600; letter-spacing:0.18em; text-transform:uppercase; color:var(--sub); margin-top:4px; }
  .dots { display:flex; gap:3px; margin:22px 0 6px; }
  .dots i { flex:1; height:3px; border-radius:2px; background:var(--hair); }
  .dots i.done { background:var(--green); }
  .dots i.cur { background:var(--lav); }
  .wiz-nav { display:flex; gap:12px; margin-top:26px; }

  .btn { flex:1; padding:16px; background:var(--ink); color:#0e0e0e; border:none; border-radius:999px; font-family:inherit; font-size:0.9rem; font-weight:700; cursor:pointer; transition:transform .12s; }
  .btn:active { transform:scale(.98); }
  .btn.lite { background:transparent; color:var(--ink); border:1px solid var(--hair); }
  .btn.green { background:var(--lav); color:#14142a; }
  .btn.txt { background:transparent; color:var(--faint); font-family:'IBM Plex Mono',monospace; font-size:0.58rem; letter-spacing:0.14em; text-transform:uppercase; padding:10px; border:none; border-radius:0; }

  .sc-scroll { overflow-x:auto; margin:0 -24px; padding:0 24px; }
  table.sc { border-collapse:collapse; font-size:0.78rem; min-width:100%; }
  table.sc th, table.sc td { padding:8px; text-align:center; white-space:nowrap; font-weight:600; }
  table.sc thead th { font-family:'IBM Plex Mono',monospace; color:var(--faint); font-weight:600; font-size:0.5rem; letter-spacing:0.14em; text-transform:uppercase; border-bottom:1px solid var(--hair); }
  table.sc tbody th { font-family:'IBM Plex Mono',monospace; text-align:left; color:var(--faint); font-weight:600; font-size:0.5rem; letter-spacing:0.14em; text-transform:uppercase; padding-right:14px; }
  table.sc tbody tr { border-bottom:1px solid var(--hair2); }
  table.sc td.tot { font-weight:800; color:var(--ink); }
  .sc-badge { display:inline-flex; width:26px; height:26px; align-items:center; justify-content:center; border-radius:50%; font-weight:800; }
  .sc-badge.birdie { background:var(--green-soft); color:var(--green); }
  .sc-badge.bogey { background:rgba(216,178,92,.14); color:#d8b25c; }
  .sc-badge.dbl { background:var(--red-soft); color:var(--red); }

  .entry-row { display:flex; align-items:center; gap:12px; padding:14px 0; flex-wrap:wrap; border-bottom:1px solid var(--hair2); }
  .entry-row:last-of-type { border-bottom:none; }
  .mini-lbl { font-family:'IBM Plex Mono',monospace; font-size:0.48rem; font-weight:600; letter-spacing:0.16em; text-transform:uppercase; color:var(--faint); text-align:center; margin-bottom:5px; }
  .stepper { display:inline-flex; align-items:center; border:1px solid var(--hair); border-radius:10px; background:var(--card); overflow:hidden; }
  .stepper button { width:38px; height:40px; border:none; background:transparent; font-size:1.2rem; font-weight:600; color:var(--sub); cursor:pointer; }
  .stepper span { min-width:32px; text-align:center; font-weight:800; font-size:1.05rem; }

  .sess { display:flex; justify-content:space-between; align-items:center; padding:20px 2px; border-bottom:1px solid var(--hair); cursor:pointer; }
  .sess .l .t { font-family:'IBM Plex Mono',monospace; font-size:0.54rem; font-weight:600; letter-spacing:0.24em; text-transform:uppercase; color:var(--green); }
  .sess .l .d { font-family:var(--disp); font-size:1.1rem; font-weight:600; letter-spacing:-0.01em; color:#e2e0da; margin-top:7px; }
  .sess .l .n { font-size:0.8rem; color:var(--sub); margin-top:6px; font-style:italic; }
  .sess .r { text-align:right; display:flex; align-items:center; gap:14px; }
  .sess .big { font-family:var(--disp); font-size:1.8rem; font-weight:600; letter-spacing:-0.02em; }
  .sess .subv { font-family:'IBM Plex Mono',monospace; font-size:0.5rem; font-weight:600; letter-spacing:0.12em; text-transform:uppercase; color:var(--sub); margin-top:3px; }
  .sess .del { background:none; border:none; color:var(--faint); font-size:0.95rem; cursor:pointer; padding:4px; }
  .sess-detail { padding:6px 0 22px; border-bottom:1px solid var(--hair); }

  .bignum-row { display:grid; grid-template-columns:1fr 1fr; gap:10px; }
  .bignum { background:var(--card); border:1px solid var(--hair2); border-radius:14px; padding:16px 14px; }
  .bignum .v { font-family:var(--disp); font-size:2.1rem; font-weight:600; letter-spacing:-0.03em; line-height:1; }
  .bignum .v.grn { color:var(--green); }
  .bignum .k { font-family:'IBM Plex Mono',monospace; font-size:0.48rem; font-weight:600; letter-spacing:0.14em; text-transform:uppercase; color:var(--sub); margin-top:10px; line-height:1.7; }
  .bench { display:flex; align-items:baseline; justify-content:space-between; padding:16px 0; border-bottom:1px solid var(--hair2); }
  .bench .n { font-size:0.88rem; font-weight:700; }
  .bench .n small { display:block; font-family:'IBM Plex Mono',monospace; font-size:0.5rem; font-weight:600; letter-spacing:0.14em; text-transform:uppercase; color:var(--faint); margin-top:5px; }
  .bench .r { display:flex; align-items:baseline; gap:10px; }
  .bench .v { font-family:var(--disp); font-size:1.35rem; font-weight:600; }
  .gap { font-family:'IBM Plex Mono',monospace; font-size:0.58rem; font-weight:600; padding:4px 9px; border-radius:999px; }
  .gap.up { background:var(--green-soft); color:var(--green); }
  .gap.dn { background:var(--red-soft); color:var(--red); }
  .hbar { margin:14px 0; }
  .hbar .lbl { display:flex; justify-content:space-between; font-size:0.8rem; font-weight:700; margin-bottom:7px; }
  .hbar .lbl span:last-child { font-family:'IBM Plex Mono',monospace; color:var(--sub); font-weight:500; font-size:0.64rem; }
  .hbar .trk { height:3px; background:var(--hair); border-radius:2px; overflow:hidden; }
  .hbar .fil { height:100%; background:var(--green); border-radius:2px; transition:width .4s; }
  .bars { display:flex; align-items:flex-end; gap:6px; height:82px; margin-top:26px; }
  .bars .b { flex:1; border-radius:3px 3px 0 0; position:relative; min-height:4px; }
  .bars .b span { position:absolute; top:-18px; left:50%; transform:translateX(-50%); font-family:'IBM Plex Mono',monospace; font-size:0.58rem; font-weight:600; }
  .coach { display:flex; gap:16px; padding:16px 0; border-bottom:1px solid var(--hair2); align-items:flex-start; }
  .coach:last-child { border-bottom:none; }
  .coach .no { font-family:'IBM Plex Mono',monospace; font-size:0.54rem; font-weight:600; color:var(--green); letter-spacing:0.1em; padding-top:4px; }
  .coach p { font-size:0.88rem; line-height:1.6; font-weight:500; color:#c9c7c0; }
  .coach p b { font-weight:800; color:var(--ink); }
  .radar-wrap { display:flex; justify-content:center; padding:6px 0 2px; }
  .empty { text-align:center; padding:54px 20px; color:var(--faint); font-family:'IBM Plex Mono',monospace; font-size:0.66rem; letter-spacing:0.1em; text-transform:uppercase; line-height:2; }
  .toast { position:fixed; bottom:92px; left:50%; transform:translateX(-50%); background:var(--ink); color:#0e0e0e; padding:12px 26px; border-radius:999px; font-family:'IBM Plex Mono',monospace; font-size:0.58rem; font-weight:600; letter-spacing:0.16em; text-transform:uppercase; opacity:0; transition:opacity .3s; pointer-events:none; z-index:99; }
  .toast.show { opacity:1; }
</style>
</head>
